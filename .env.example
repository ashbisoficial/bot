BOT_TOKEN=tu_token_del_bot_aca
GUILD_ID=id_de_tu_servidor_aca

# Opcional: si lo dejás vacío, el bot funciona igual pero sin responder
# preguntas (no hace falta para moderación ni /changelog).
ANTHROPIC_API_KEY=tu_api_key_de_anthropic_aca
# Opcional: modelo a usar para el asistente. Por defecto usa Opus (más caro,
# más capaz). Para bajar costo en un server con mucho tráfico, probá con
# claude-haiku-4-5.
ANTHROPIC_MODEL=claude-opus-4-8
